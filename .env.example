APP_ENV=development
DATABASE_URL=sqlite:///./data/sample_factory.db
REDIS_URL=redis://localhost:6379/0
SCAN_API_KEY=replace-with-real-scan-key
ADMIN_API_KEY=replace-with-real-admin-key
JWT_SECRET_KEY=replace-with-real-jwt-secret
IMPORT_MAX_BYTES=1048576
IMPORT_MAX_RECORDS=500
SIMILARITY_THRESHOLD=0.55
EXPORT_DIR=./data/exports
